<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:flutter="clr-namespace:Flutter.MAUI;assembly=Flutter"
             x:Class="FlutterSample.MAUI.ListDemoPage"
             Title="List Demo">

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- MAUI header -->
        <VerticalStackLayout Grid.Row="0" Padding="10" BackgroundColor="{StaticResource Primary}">
            <Label Text="List Demo"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />
            <Label Text="Flutter ListView with dynamic items"
                   FontSize="14"
                   TextColor="White"
                   Opacity="0.8"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- FlutterView for Flutter list content -->
        <flutter:FlutterView x:Name="flutterView"
                            Grid.Row="1"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />

        <!-- MAUI controls for list manipulation -->
        <HorizontalStackLayout Grid.Row="2"
                              Padding="20"
                              Spacing="10"
                              HorizontalOptions="Center"
                              BackgroundColor="{StaticResource Gray100}">
            <Entry x:Name="itemEntry"
                   Placeholder="Enter item text"
                   WidthRequest="200" />
            <Button Text="Add Item"
                    Clicked="OnAddItemClicked" />
            <Button Text="Clear All"
                    Clicked="OnClearClicked" />
        </HorizontalStackLayout>
    </Grid>

</ContentPage>
