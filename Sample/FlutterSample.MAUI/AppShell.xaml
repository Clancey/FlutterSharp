<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:FlutterSample.MAUI"
       x:Class="FlutterSample.MAUI.AppShell"
       Title="FlutterSharp Sample">

    <Shell.FlyoutBehavior>
        <OnPlatform x:TypeArguments="FlyoutBehavior">
            <On Platform="iOS" Value="Disabled" />
            <On Platform="Android" Value="Disabled" />
        </OnPlatform>
    </Shell.FlyoutBehavior>

    <ShellContent
        Title="Demo"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
